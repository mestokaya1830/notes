

npm install -D bootstrap@5.3.3
npm install
aad this in resources/css/app.css and resources/js/app.js
@import 'bootstrap';



pagination
Go to your app/Providers/AppServiceProvider.php file. Then add use Illuminate\Pagination\Paginator; and find out the boot() function. Then write this line Paginator::useBootstrap(); inside the function.

use Illuminate\Pagination\Paginator;

public function boot()
{
    Paginator::useBootstrap();
}
