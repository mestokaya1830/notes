
SHORTHAND FOR STOP, START AND REMOVE-------------------------------
sudo docker stop container_name
sudo docker start container_name
sudo docker rm container_name

NGINX----------------------------------------------
sudo docker pull nginx
sudo docker run -it -d -p 8080:80 nginx       //8080 is docker port it can be change by you
open browser and type localhost:8080
sudo docker ps
sudo docker container stop id

add file in nginx folder
sudo nano ~/test/index.html  //path must be so ~/
sudo docker run --name nginx1 -it -d -p 8080:80 -v ~/test:/usr/share/nginx/html nginx

MONGO-----------------------------------------------
sudo docker pull mongo //install mongo
sudo docker run -d -p 27017:27017 -v data:/data/db mongo
sudo docker ps
sudo docker container stop id


MYSQL----------------------------------------------
sudo docker pull mysql
sudo docker run -d --name mysql-server -p 3306:3306 -e "MYSQL_ROOT_PASSWORD=9090" mysql
sudo mkdir /var/lib/mysql -p
docker run -d --name mysql-server -p 3306:3306 -v /var/lib/mysql:/var/lib/mysql -e "MYSQL_ROOT_PASSWORD=9090" mysql
sudo docker ps
sudo docker container stop id
